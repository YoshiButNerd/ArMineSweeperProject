<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".AdminMainActivity">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/trans_gray"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.3"
        app:layout_constraintWidth_percent="0.95">

        <TextView
            android:id="@+id/AdminTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="35dp"
            android:gravity="center"
            android:letterSpacing="0.01"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="7"
            android:text="דף מנהל"
            android:textColor="@color/dark_gray"
            android:textSize="45sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aGoGameBtn"
            style="@style/BasicButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:text="שחק"
            android:textSize="18sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aGoTutorialBtn"
            style="@style/BasicButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="חוקי המשחק"
            android:textSize="18sp"
            android:layout_marginBottom="22dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aGoInfoBtn"
            style="@style/BasicButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:text="אודות"
            android:textSize="18sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aGoInfoUsersBtn"
            style="@style/BasicButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:text="טבלת משתמשים"
            android:textSize="18sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aGoLoginBtn"
            style="@style/BasicButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="התנתק"
            android:textSize="18sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>