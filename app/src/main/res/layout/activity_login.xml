<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity"
    android:background="@drawable/background">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/trans_gray"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.15"
        app:layout_constraintWidth_percent="0.97">

        <TextView
            android:id="@+id/txtTitleLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="כניסה"
            android:letterSpacing="0.01"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="7"
            android:textColor="@color/dark_gray"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="50sp"
            android:layout_margin="15sp"/>

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:srcCompat="@mipmap/minesweeperlogo" />

        <EditText
            android:id="@+id/etLoginEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:ems="10"
            android:gravity="center"
            android:hint="אימייל"
            android:textColor="@color/black"
            android:textColorHint="@color/dark_gray"
            android:inputType="textEmailAddress"
            android:background="@color/low_trans_gray"
            android:layout_margin="10dp"/>

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:ems="10"
            android:inputType="textPassword"
            android:hint="סיסמה"
            android:gravity="center"
            android:textColor="@color/black"
            android:textColorHint="@color/dark_gray"
            android:background="@color/low_trans_gray"
            android:layout_margin="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="15dp"
            android:layout_margin="5dp">

            <com.google.android.material.button.MaterialButton
                style="@style/BasicButton"
                android:id="@+id/btnLoginLog"
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="4dp"
                android:text="התחברות" />

            <com.google.android.material.button.MaterialButton
                style="@style/BasicButton"
                android:id="@+id/btnGoRegisterReg"
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:text="אין לי משתמש" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>