<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">


    <TextView
        android:id="@+id/shopTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="חנות"
        android:textStyle="bold"
        android:textSize="40sp"
        android:gravity="center"
        android:letterSpacing="0.02"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="7"
        android:textColor="@color/dark_gray"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <LinearLayout
        android:id="@+id/topRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/shopTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/heartUpBtn"
            style="@style/BasicButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="לב\nמחיר: 10"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:gravity="right">

            <TextView
                android:id="@+id/moneyTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="כסף: 0"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:gravity="right"/>

            <TextView
                android:id="@+id/healthTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="לבבות: 3"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:gravity="right"/>

        </LinearLayout>

    </LinearLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/itemsRow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginVertical="40dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/topRow"
        app:layout_constraintBottom_toTopOf="@id/goNextBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/item1Btn"
            style="@style/BasicButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="Item 1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/item2Btn"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/item2Btn"
            style="@style/BasicButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="Item 2"
            android:layout_marginHorizontal="6dp"
            app:layout_constraintStart_toEndOf="@id/item1Btn"
            app:layout_constraintEnd_toStartOf="@id/item3Btn"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/item3Btn"
            style="@style/BasicButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="Item 3"
            app:layout_constraintStart_toEndOf="@id/item2Btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/goNextBtn"
        style="@style/BasicButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="המשך"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>