<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ShopActivity"
    android:background="@color/material_dynamic_neutral_variant90">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp"
        android:gravity="center">

        <TextView
            android:id="@+id/shopTitle"
            android:layout_width="250dp"
            android:layout_height="75dp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="חנות"
            android:textSize="60sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/heartUpBtn"
                android:layout_width="120dp"
                android:layout_height="54dp"
                android:textSize="13sp"
                android:background="@drawable/button_background"
                android:text="
לב
\n
מחיר: 10
"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="8dp">

                <TextView
                    android:id="@+id/moneyTxt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:text="כסף: 0"/>

                <TextView
                    android:id="@+id/healthTxt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:text="לבבות: 3"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="50"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/item1Btn"
                android:layout_width="120dp"
                android:layout_height="350dp"
                android:background="@drawable/button_background"
                android:text="Item 1" />

            <Button
                android:id="@+id/item2Btn"
                android:layout_width="120dp"
                android:layout_height="350dp"
                android:text="Item 2"
                android:background="@drawable/button_background"
                android:layout_marginHorizontal="20dp" />

            <Button
                android:id="@+id/item3Btn"
                android:layout_width="120dp"
                android:layout_height="350dp"
                android:background="@drawable/button_background"
                android:text="Item 3" />

        </LinearLayout>

        <Button
            android:id="@+id/goNextBtn"
            android:layout_width="200dp"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:layout_marginBottom="50dp"
            android:text="המשך" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>