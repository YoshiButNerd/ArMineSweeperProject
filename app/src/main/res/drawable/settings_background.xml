<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- base color -->
    <item>
        <shape>
            <solid android:color="#28323B" />
        </shape>
    </item>

    <!-- light effect -->
    <item android:bottom="400dp">
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="100%p"
                android:centerX="50%"
                android:centerY="0%"
                android:startColor="#668ECDF5"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- overlay -->
    <item>
        <shape>
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF" />

            <gradient
                android:type="radial"
                android:gradientRadius="85%p"
                android:startColor="#00000000"
                android:endColor="#22000000" />
        </shape>
    </item>

</layer-list>