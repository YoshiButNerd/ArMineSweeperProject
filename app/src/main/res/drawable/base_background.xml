<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. THE MAIN BODY (Slightly lighter than the bottom of your background) -->
    <item>
        <shape>
            <solid android:color="#1A1D23" />
        </shape>
    </item>

    <!-- 2. THE TOP EDGE LIGHT (This kills the flatness) -->
    <!-- A very bright 1dp line at the very top -->
    <item> <!-- Adjust this based on your toolbar height -->
        <shape>
            <solid android:color="#4DFFFFFF" />
        </shape>
    </item>

    <!-- 3. THE BOTTOM SHADOW (Gives it a "lift") -->
    <!-- A dark gradient at the very bottom edge -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#66000000"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- 4. INNER GLOW (Makes the center feel hollow/glassy) -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="#1A5DADE2"
                android:centerColor="#00000000"
                android:endColor="#00000000" />
        </shape>
    </item>

</layer-list>